{
  "name": "opencode-config",
  "version": "1.0.0",
  "description": "For developing opencode plugins.",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.41",
    "@types/bun": "^1.3.13",
    "@types/node": "^24.3.1",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "validate:templates": "sh ../scripts/validate-file-interp.sh",
    "check": "bun run typecheck && bun run validate:templates",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "dependencies": {}
}
{
  "name": "opencode-config",
  "version": "1.0.0",
  "description": "For developing opencode plugins.",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@opencode-ai/plugin": "^0.6.9",
    "@types/bun": "^1.3.13",
    "@types/node": "^24.3.1",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test plugins/file-interp.test.ts",
    "validate:templates": "bun run ../scripts/validate-file-interp.ts",
    "check": "bun run typecheck && bun run test && bun run validate:templates",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@opencode-ai/plugin": "0.0.0-production-202604141138"
  }
}

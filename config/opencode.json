{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "instructions": [
    "CLAUDE.md",
  ],
  "permission": {
    "bash": {
      "*": "allow"
    },
    "task": {
      "discord-messages": "deny"
    },
    "webfetch": "allow",
    "doom_loop": "deny",
    "github_*": "deny",
    "discord_*": "deny",
    "context7_*": "deny",
    "deepwiki_*": "deny",
    "external_directory": "allow"
  },
  "agent": {
    "plan": {
      "permission": {
        "task": {
          "_orchestrator/*": "deny",
          "_plan/reviewers/*": "deny",
          "_implement/*": "deny",
          "commit": "deny",
          "coderabbit": "deny",
          "mcp-search": "allow"
        }
      }
    },
    "build": {
      "permission": {
        "task": {
          "_orchestrator/*": "deny",
          "_plan/reviewers/*": "deny",
          "_implement/*": "deny",
          "commit": "deny",
          "coderabbit": "deny",
          "mcp-search": "deny"
        }
      }
    },
    "general": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "permission": {
        "task": {
          "_orchestrator/*": "deny",
          "_plan/reviewers/*": "deny",
          "_implement/*": "deny",
          "commit": "deny",
          "coderabbit": "deny",
          "mcp-search": "allow"
        }
      }
    },
    "explore": {
      "disable": true
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "if [ ! -f \"$HOME/.secrets/github-token\" ]; then echo \"Error: GitHub token secret file not found\" >&2; exit 1; fi; export GITHUB_PERSONAL_ACCESS_TOKEN=\"$(cat \"$HOME/.secrets/github-token\")\"; exec docker run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN ghcr.io/github/github-mcp-server"
      ],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/sse",
      "enabled": true
    },
    "discord": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "if [ ! -f \"$HOME/.secrets/discord-token\" ]; then echo \"Error: Discord token secret file not found\" >&2; exit 1; fi; export DISCORD_TOKEN=\"$(cat \"$HOME/.secrets/discord-token\")\"; exec docker run -i --rm -e DISCORD_TOKEN barryy625/mcp-discord:latest"
      ],
      "enabled": true
    }
  },
  "provider": {
    "openai": {
      "options": {
        "reasoningSummary": "concise"
      }
    },
    "synthetic": {
      "models": {
        "hf:Qwen/Qwen3.5-397B-A17B": {
          "id": "hf:Qwen/Qwen3.5-397B-A17B"
        },
        "hf:MiniMaxAI/MiniMax-M2.5": {
          "id": "hf:MiniMaxAI/MiniMax-M2.5"
        },
        "hf:zai-org/GLM-5": {
          "id": "hf:zai-org/GLM-5",
          "name": "GLM-5",
          "family": "glm",
          "release_date": "2026-03-01",
          "last_updated": "2026-03-01",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "open_weights": true,
          "cost": {
            "input": 0,
            "output": 0
          },
          "limit": {
            "context": 192000,
            "output": 131072
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "zai-coding-plan": {
      "models": {
        "glm-5-turbo": {
          "id": "glm-5-turbo",
          "name": "GLM-5-Turbo",
          "family": "glm",
          "release_date": "2026-02-11",
          "last_updated": "2026-02-11",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "open_weights": true,
          "cost": {
            "input": 0,
            "output": 0
          },
          "limit": {
            "context": 204800,
            "output": 131072
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "github-copilot": {
      "options": {
        "reasoningSummary": "concise"
      },
      "models": {
        "gpt-5.3-codex": {
          "id": "gpt-5.3-codex",
          "name": "GPT-5.3-Codex",
          "family": "gpt-codex",
          "release_date": "2026-02-05",
          "last_updated": "2026-02-05",
          "attachment": true,
          "reasoning": true,
          "temperature": false,
          "knowledge": "2025-08-31",
          "tool_call": true,
          "structured_output": true,
          "open_weights": false,
          "cost": {
            "input": 0,
            "output": 0
          },
          "limit": {
            "context": 400000,
            "input": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  // Disable paste summary. Paste whole thing.
  "experimental": {
    "disable_paste_summary": true,
  },
}
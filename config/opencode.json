{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": [
    "@sewer56/opencode-models-discovery@0.9.1"
  ],
  "small_model": "sewer-axonhub/step-3.7-flash",
  "permission": {
    "bash": {
      "*": "allow"
    },
    "task": {
      "discord-messages": "deny"
    },
    "webfetch": "allow",
    "doom_loop": "deny",
    "github_*": "deny",
    "discord_*": "deny",
    "context7_*": "deny",
    "deepwiki_*": "deny",
    "external_directory": "allow"
  },
  "agent": {
    "plan": {
      "permission": {
        "task": {
          "*": "deny",
          "general": "allow",
          "mcp-search": "allow",
          "codebase-explorer": "allow"
        }
      }
    },
    "build": {
      "permission": {
        "task": {
          "*": "deny",
          "general": "allow",
          "mcp-search": "allow",
          "codebase-explorer": "allow"
        }
      }
    },
    "general": {
      "model": "sewer-axonhub/deepseek-v4-flash",
      "permission": {
        "task": {
          "*": "deny",
          "mcp-search": "allow"
        }
      }
    },
    "explore": {
      "disable": true
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "if [ ! -f \"$HOME/.secrets/github-token\" ]; then echo \"Error: GitHub token secret file not found\" >&2; exit 1; fi; export GITHUB_PERSONAL_ACCESS_TOKEN=\"$(cat \"$HOME/.secrets/github-token\")\"; exec docker run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN ghcr.io/github/github-mcp-server"
      ],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/sse",
      "enabled": true
    },
    "discord": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "if [ ! -f \"$HOME/.secrets/discord-token\" ]; then echo \"Error: Discord token secret file not found\" >&2; exit 1; fi; export DISCORD_TOKEN=\"$(cat \"$HOME/.secrets/discord-token\")\"; exec docker run -i --rm -e DISCORD_TOKEN barryy625/mcp-discord:latest"
      ],
      "enabled": false
    }
  },
  "provider": {
    "github-copilot": {
      "options": {
        "reasoningSummary": "concise"
      }
    },
    "sewer-axonhub": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Sewer AxonHub",
      "options": {
        "baseURL": "{file:/home/sewer/.secrets/axonhub-url}",
        "apiKey": "{file:/home/sewer/.secrets/axonhub-key}",
        "modelsDiscovery": {
          "enabled": true
        }
      }
    },
    "sewer-axonhub-work": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "AxonHub (Work Mode)",
      "options": {
        "baseURL": "{file:/home/sewer/.secrets/axonhub-url}",
        "apiKey": "{file:/home/sewer/.secrets/axonhub-work-key}",
        "modelsDiscovery": {
          "enabled": true
        }
      }
    }
  },
  "experimental": {
    "disable_paste_summary": true
  }
}
# Usage:
#   direnv allow
#
# Loads the root flake dev shell for Go utility development and makes `go test`
# work on Nix without C toolchain/linker surprises. path:$(pwd -P) keeps
# direnv working through the ~/opencode symlink and before new flake files are
# committed to git.
use flake "path:$(pwd -P)" --impure
export CGO_ENABLED=0
